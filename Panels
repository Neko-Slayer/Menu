# Function to run FeatherPanel installer
install_feather() {
    echo -e "\n${BLUE}[+] Running FeatherPanel installer...${NC}"
    bash <(curl -fsSL https://raw.githubusercontent.com/Neko-Slayer/Menu/main/Feather.sh)
}

# Function to run Pterodactyl installer
install_ptero() {
    echo -e "\n${BLUE}[+] Running Pterodactyl installer...${NC}"
    bash <(curl -sSL https://raw.githubusercontent.com/Neko-Slayer/Menu/main/Pteromenu.sh)
}

# Function to run Paymenter installer
install_paymenter() {
    echo -e "\n${BLUE}[+] Running Paymenter installer...${NC}"
    bash <(curl -fsSL https://raw.githubusercontent.com/Neko-Slayer/Menu/main/Paymenter.sh)
}

# Function to run MythicalDash installer
install_mythical() {
    echo -e "\n${BLUE}[+] Running MythicalDash installer...${NC}"
    bash <(curl -fsSL https://raw.githubusercontent.com/Neko-Slayer/Menu/main/mythicaldash.sh)
}

# Function to run Jexactyl installer
install_jexactyl() {
    echo -e "\n${BLUE}[+] Running Jexactyl installer...${NC}"
    bash <(curl -fsSL https://raw.githubusercontent.com/Neko-Slayer/Menu/main/jexactyl.sh)
}

# Check if running as root
if [[ $EUID -ne 0 ]]; then
   echo -e "${RED}[✘] This script must be run as root!${NC}"
   echo -e "${YELLOW}Usage: sudo bash $0${NC}\n"
   exit 1
fi

# Main loop
while true; do
    show_menu
    
    # Get user choice
    read -p "Enter your choice [0-5]: " choice
    
    case $choice in
        1)
            install_feather
            ;;
        2)
            install_ptero
            ;;
        3)
            install_paymenter
            ;;
        4)
            install_mythical
            ;;
        5)
            install_jexactyl
            ;;
        0)
            echo -e "\n${GREEN}👋 Goodbye! Thanks for using Neko Menu!${NC}\n"
            exit 0
            ;;
        *)
            echo -e "\n${RED}[✘] Invalid choice! Please enter 0-5${NC}"
            sleep 2
            ;;
    esac
    
    # After installation, ask to continue or exit
    if [[ $choice -ge 1 && $choice -le 5 ]]; then
        echo -e "\n${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        read -p "Press Enter to continue or 'q' to quit: " continue_choice
        if [[ "$continue_choice" == "q" ]]; then
            echo -e "\n${GREEN}👋 Goodbye! Thanks for using Neko Menu!${NC}\n"
            exit 0
        fi
    fi
done
