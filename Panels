    # Bada NEKO Banner
    echo -e "${CYAN}"
    echo ' ███╗   ██╗███████╗██╗  ██╗ ██████╗ '
    echo ' ████╗  ██║██╔════╝██║ ██╔╝██╔═══██╗'
    echo ' ██╔██╗ ██║█████╗  █████╔╝ ██║   ██║'
    echo ' ██║╚██╗██║██╔══╝  ██╔═██╗ ██║   ██║'
    echo ' ██║ ╚████║███████╗██║  ██╗╚██████╔╝'
    echo ' ╚═╝  ╚═══╝╚══════╝╚═╝  ╚═╝ ╚═════╝ '
    echo -e "${NC}"
    echo -e "${PURPLE}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "${WHITE}              🚀 PANEL INSTALLATION MENU 🚀${NC}"
    echo -e "${PURPLE}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "${YELLOW}                Made by NekoSlayer_${NC}"
    echo -e "${PURPLE}═══════════════════════════════════════════════════════════════${NC}\n"
    
    # Menu Options
    echo -e "${GREEN}📌 AVAILABLE PANELS:${NC}"
    echo -e "${WHITE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e " ${CYAN}[1]${NC} ${WHITE}FeatherPanel${NC}     - Lightweight hosting panel"
    echo -e " ${CYAN}[2]${NC} ${WHITE}Pterodactyl${NC}     - Game panel & billing system"
    echo -e " ${CYAN}[3]${NC} ${WHITE}Paymenter${NC}        - Billing & client management"
    echo -e " ${CYAN}[4]${NC} ${WHITE}MythicalDash${NC}     - Pterodactyl client area"
    echo -e " ${CYAN}[5]${NC} ${WHITE}Jexactyl${NC}         - Enhanced Pterodactyl panel"
    echo -e "${WHITE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e " ${RED}[0]${NC} ${WHITE}Exit${NC}              - Close menu"
    echo -e "${WHITE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
